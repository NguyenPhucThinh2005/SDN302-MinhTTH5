<%- include('../partials/header') %>

<h2>Edit Question</h2>

<form action="/questions/<%= question._id || question.Object_id %>?_method=PUT" method="POST">
    <div class="mb-3">
        <label for="text" class="form-label">Question Text</label>
        <input type="text" class="form-control" id="text" name="text" value="<%= question.text %>" required>
    </div>
    <div class="mb-3">
        <label for="options" class="form-label">Options (comma separated)</label>
        <input type="text" class="form-control" id="options" name="options" value="<%= question.options ? question.options.join(', ') : '' %>" required>
    </div>
    <div class="mb-3">
        <label for="correctAnswerIndex" class="form-label">Correct Answer Index (0-based)</label>
        <input type="number" class="form-control" id="correctAnswerIndex" name="correctAnswerIndex" value="<%= question.correctAnswerIndex %>" required min="0">
    </div>
    <div class="mb-3">
        <label for="keywords" class="form-label">Keywords (comma separated)</label>
        <input type="text" class="form-control" id="keywords" name="keywords" value="<%= question.keywords ? question.keywords.join(', ') : '' %>">
    </div>
    <button type="submit" class="btn btn-primary">Update</button>
    <a href="/questions" class="btn btn-secondary">Cancel</a>
</form>

<%- include('../partials/footer') %>
