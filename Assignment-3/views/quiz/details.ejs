<%- include('../partials/header.hbs') %>

<h2>Quiz Details</h2>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title"><%= quiz.title %></h5>
        <p class="card-text"><%= quiz.description %></p>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Questions in this Quiz</h4>
    <a href="/quizzes/<%= quiz._id || quiz.Object_id %>/questions/create" class="btn btn-success btn-sm">Add Question</a>
</div>
<ul class="list-group">
    <% if(quiz.questions && quiz.questions.length > 0) { %>
        <% quiz.questions.forEach(q => { %>
            <li class="list-group-item">
                <strong><%= q.text %></strong>
                <ul>
                    <% if(q.options) { q.options.forEach((opt, idx) => { %>
                        <li><%= opt %> <% if(idx === q.correctAnswerIndex) { %> <span class="badge bg-success">Correct</span> <% } %></li>
                    <% }) } %>
                </ul>
            </li>
        <% }) %>
    <% } else { %>
        <li class="list-group-item">No questions found for this quiz.</li>
    <% } %>
</ul>

<a href="/quizzes" class="btn btn-secondary mt-3">Back to List</a>
<a href="/quizzes/<%= quiz._id || quiz.Object_id %>/edit" class="btn btn-warning mt-3 ms-2">Edit</a>

<%- include('../partials/footer.hbs') %>
